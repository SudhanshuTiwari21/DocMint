# Razorpay: use Test Mode API keys from Dashboard when testing; switch to Live keys for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
JWT_SECRET=
# Get from Neon (or your DB) dashboard. Never commit the real URL.
DATABASE_URL=

# Email: use Resend on Vercel (recommended). Get key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Dockera <info@dockera.in>

# Or use SMTP (e.g. GoDaddy). Often blocked from Vercel.
# GoDaddy Workspace Email — use your full email as SMTP_USER
# Microsoft 365 from GoDaddy: host smtp.office365.com, port 587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Dockera <info@dockera.in>
