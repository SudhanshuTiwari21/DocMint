# Razorpay: use Test Mode API keys from Dashboard when testing; switch to Live keys for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: create Plans in Dashboard (Payment products → Subscriptions → Plans), then paste IDs here to avoid "Failed to get plan"
# RAZORPAY_PLAN_MONTHLY_ID=
# RAZORPAY_PLAN_YEARLY_ID=
# Webhook secret from Razorpay Dashboard → Settings → Webhooks (required to sync cancelled/expired subscriptions and renewals)
# RAZORPAY_WEBHOOK_SECRET=
# Secret for cron endpoints (e.g. renewal reminders). Set in Vercel and pass as Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
JWT_SECRET=
# Get from Neon (or your DB) dashboard. Never commit the real URL.
DATABASE_URL=
# Email: use Resend on Vercel (recommended). Get key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Dockera <info@dockera.in>

# Or use SMTP (e.g. GoDaddy). Often blocked from Vercel.
# GoDaddy Workspace Email — use your full email as SMTP_USER
# Microsoft 365 from GoDaddy: host smtp.office365.com, port 587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Dockera <info@dockera.in>

# DocChat: OpenAI (text-embedding-3-small for embeddings, gpt-4o-mini for chat)
OPENAI_API_KEY=
# DocChat: Pinecone – create a free serverless index at https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX=